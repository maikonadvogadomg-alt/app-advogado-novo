# ============================================================
# ARQUIVO DE EXEMPLO - VARIAVEIS DE AMBIENTE
# Copie para .env e preencha com seus valores reais.
# ============================================================

# MOCK_MODE=true: desativa chamadas externas e usa mock
# MOCK_MODE=false: usa APIs reais configuradas
MOCK_MODE=false

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here
AI_INTEGRATIONS_GEMINI_BASE_URL=http://localhost:1106/modelfarm/gemini

# Banco Neon
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
PGDATABASE=neondb
PGHOST=your-neon-host.neon.tech
PGPORT=5432
PGUSER=neondb_owner
PGPASSWORD=your_pg_password_here

# Sessao
SESSION_SECRET=your_long_random_session_secret_here
APP_PASSWORD=your_app_password_here

# Juridico / APIs opcionais
PDPJ_PEM_PRIVATE_KEY=
DATAJUD_API_KEY=
DJEN_API_URL=https://comunicaapi.pje.jus.br/api/v1/comunicacao
DJEN_TOKEN=

# Robo juridico (Gmail/Drive opcionais)
EMAIL_LOGIN=seu_email@gmail.com
SENHA_APP=sua_senha_de_aplicativo
IMAP_SERVER=imap.gmail.com
PASTA_DRAFTS=[Gmail]/Rascunhos
ARQUIVO_CLIENTES=clientes.xlsx
SALVAR_NO_DRIVE=false
PASTA_DRIVE_ID=sua_id_da_pasta_no_drive

# Servidor
NODE_ENV=development
PORT=5000
